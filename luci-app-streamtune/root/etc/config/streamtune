config streamtune 'global'
	# активный профиль: generic | lte_audio
	option profile 'generic'
	# WAN-интерфейс для MTU/MSS (пусто = автоопределение)
	option wan_iface ''
	# безопасный профиль включён по умолчанию
	option net_buffers '1'
	option low_latency '1'
	option backlog '1'
	option conntrack '1'
	option flow_offload '1'
	# опциональные/рискованные — выключены по умолчанию
	option flow_offload_hw '0'
	option congestion '0'
	option irqbalance '0'
	option disable_ipv6 '0'
	# целевой размер хэш-таблицы conntrack
	option hashsize '16384'
	# порог размера tcp_bbr.ko (байт) для определения v1/v3 (modinfo вырезан в OpenWRT);
	# > порога => BBR v3. Дефолт под ImmortalWRT 25.12 mediatek (сток v1 ~13856).
	option bbr_v1_maxsize '14500'
