#!/bin/sh
# rpcd-бэкенд для luci-app-streamtune.
# SPDX-License-Identifier: GPL-2.0
#
# Тонкий мост ubus<->shell: get_status/get_boot/probe_mtu отдают JSON автономных
# скриптов, apply пишет профиль + список выключенных параметров (param_off) в UCI
# и запускает apply.sh, revert — откат. Реестр и логика — в /usr/share/streamtune/.
. /usr/share/libubox/jshn.sh

ST_SHARE="${ST_SHARE:-/usr/share/streamtune}"
. "$ST_SHARE/lib.sh"

ensure_cfg() {
	uci -q get streamtune.global >/dev/null 2>&1 || {
		uci set streamtune.global=streamtune
		uci commit streamtune
	}
}

case "$1" in
	list)
		cat <<JSON
{ "get_status":{}, "get_boot":{}, "probe_mtu":{},
  "apply":{ "profile":"", "param_off":"", "wan_iface":"", "mtu":"" },
  "revert":{} }
JSON
		;;
	call)
		case "$2" in
			get_status)
				sh "$ST_SHARE/detect.sh" ;;
			get_boot)
				sh "$ST_SHARE/boot.sh" ;;
			probe_mtu)
				sh "$ST_SHARE/mtu_probe.sh" ;;
			apply)
				read -r input
				json_load "$input"
				ensure_cfg
				# профиль (только известные значения)
				json_get_var prof profile
				case "$prof" in
					lte_audio|home_wired) uci set "streamtune.global.profile=$prof" ;;
				esac
				# param_off: список выключенных ключей (валидируем по реестру)
				json_get_var poff param_off
				uci -q delete streamtune.global.param_off 2>/dev/null
				all_keys=$(st_registry | cut -d'|' -f2)
				oldIFS=$IFS; IFS=', '
				for k in $poff; do
					[ -n "$k" ] || continue
					case " $all_keys " in
						*" $k "*) uci add_list "streamtune.global.param_off=$k" ;;
					esac
				done
				IFS=$oldIFS
				# WAN-интерфейс (опционально, валидное имя секции UCI)
				json_get_var wif wan_iface
				case "$wif" in
					"" ) : ;;
					*[!a-zA-Z0-9_]* ) : ;;
					* ) uci set "streamtune.global.wan_iface=$wif" ;;
				esac
				# MTU: 'auto' или число 576..9000
				json_get_var mtuv mtu
				case "$mtuv" in
					auto) uci set "streamtune.global.mtu=auto" ;;
					''|*[!0-9]*) : ;;
					*) [ "$mtuv" -ge 576 ] && [ "$mtuv" -le 9000 ] && uci set "streamtune.global.mtu=$mtuv" ;;
				esac
				uci commit streamtune
				sh "$ST_SHARE/apply.sh" apply ;;
			revert)
				sh "$ST_SHARE/apply.sh" revert ;;
			*)
				echo '{"error":"not_implemented"}' ;;
		esac
		;;
esac
