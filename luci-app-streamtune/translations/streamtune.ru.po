msgstr "Применено %d из %d включённых оптимизаций"

msgid "All set"
msgstr "Всё применено"

msgid "Optimizations applied."
msgstr "Оптимизации применены."

msgid "Apply failed."
msgstr "Не удалось применить."

msgid "Applied with notes: %s"
msgstr "Применено с замечаниями: %s"

msgid "Recommended profile selected. Press “Apply selected” to activate."
msgstr "Выбран рекомендуемый профиль. Нажмите «Применить выбранное», чтобы активировать."

msgid "Revert all StreamTune optimizations and reset all toggles?"
msgstr "Сбросить все оптимизации StreamTune и обнулить все переключатели?"

msgid "Reverted. Buffer-size sysctls return to defaults after reboot."
msgstr "Сброшено. Sysctl-буферы вернутся к значениям по умолчанию после перезагрузки."

# ---- diagnostics ----
msgid "MB"
msgstr "МБ"

msgid "Further optimization ideas"
msgstr "Идеи для дальнейшей оптимизации"

msgid "Device-specific tweaks that StreamTune does not apply automatically."
msgstr "Зависящие от устройства настройки, которые StreamTune не применяет автоматически."

msgid "Trim unused kernel modules from /etc/modules.d/* to shorten boot time."
msgstr "Уберите неиспользуемые модули ядра из /etc/modules.d/*, чтобы сократить время загрузки."

msgid "On slow WAN links, install luci-app-sqm (CAKE/fq_codel) to fight bufferbloat — needs your real up/down speeds."
msgstr "На медленных WAN-линках установите luci-app-sqm (CAKE/fq_codel) против bufferbloat — нужны реальные скорости вверх/вниз."

msgid "Empty PCIe slots can add multi-second probe timeouts at boot; this usually requires a device-tree (DTS) change."
msgstr "Пустые слоты PCIe могут добавлять многосекундные таймауты при загрузке; обычно это требует правки device-tree (DTS)."

msgid "Keep the LTE/5G modem on IPv4-only if your operator does not need IPv6 — avoids extra session setup delay."
msgstr "Держите LTE/5G-модем только на IPv4, если оператору не нужен IPv6 — это убирает лишнюю задержку установки сессии."

msgid "Boot log (dmesg) is not available on this device."
msgstr "Журнал загрузки (dmesg) недоступен на этом устройстве."

msgid "s to userspace"
msgstr "с до userspace"

msgid "s"
msgstr "с"

msgid "Boot timeline"
msgstr "Хронология загрузки"

msgid "Kernel milestones parsed from dmesg."
msgstr "Этапы ядра, разобранные из dmesg."

msgid "System"
msgstr "Система"

msgid "Resources relevant to network load."
msgstr "Ресурсы, важные для сетевой нагрузки."

msgid "CPU cores"
msgstr "Ядра CPU"

msgid "RAM total"
msgstr "Всего ОЗУ"

msgid "RAM available"
msgstr "Доступно ОЗУ"

msgid "Tracked connections"
msgstr "Отслеживаемые соединения"

# ---- v1.2: профили, mobile_lte, BBR-версия ----
msgid "Generic"
msgstr "Базовый"

msgid "Auto LTE / audio"
msgstr "Авто LTE / аудио"

msgid "Profile:"
msgstr "Профиль:"

msgid "Profile changed but not applied yet — press “Apply selected”."
msgstr "Профиль изменён, но ещё не применён — нажмите «Применить выбранное»."

msgid "Profile “%s” selected. Press “Apply selected” to activate."
msgstr "Выбран профиль «%s». Нажмите «Применить выбранное», чтобы активировать."

msgid "Tune the network stack for low-latency, low-jitter audio/video streaming. Pick a profile, review each parameter and apply."
msgstr "Настройка сетевого стека под аудио-/видео-стриминг с низкой задержкой и джиттером. Выберите профиль, просмотрите параметры и примените."

msgid "Revert all StreamTune optimizations and reset to the Generic profile?"
msgstr "Сбросить все оптимизации StreamTune и вернуться к базовому профилю?"

msgid "Mobile LTE link"
msgstr "Мобильный LTE-канал"

msgid "Forwarded-traffic fixes that actually matter on a cellular link: MTU + MSS clamp (prevents TLS blackhole stalls) and a generous conntrack timeout."
msgstr "Исправления для форвардимого трафика, реально важные на сотовом канале: MTU + MSS-clamp (предотвращает залипания из-за блэкхола TLS) и щедрый conntrack-таймаут."

msgid "On mobile carriers this BREAKS 464XLAT/CLAT and can kill connectivity — keep IPv6 enabled. No audio benefit."
msgstr "На мобильных операторах это ЛОМАЕТ 464XLAT/CLAT и может убить связь — оставьте IPv6 включённым. Для звука пользы нет."

msgid "conntrack TCP timeout"
msgstr "TCP-таймаут conntrack"

msgid "WAN MTU"
msgstr "MTU на WAN"

msgid "MSS clamping"
msgstr "MSS-clamping"

msgid "Established-TCP conntrack timeout (seconds); keep generous so idle audio streams are not reaped from NAT."
msgstr "Таймаут established-TCP в conntrack (сек); держите щедрым, чтобы тихие аудиопотоки не выпадали из NAT."

msgid "WAN MTU; ~1430 compensates cellular tunnel overhead."
msgstr "MTU на WAN; ~1430 компенсирует туннельный оверхед сотовой сети."

msgid "Clamp TCP MSS to the path MTU so large TLS packets do not silently blackhole on the cellular link."
msgstr "Прижать TCP MSS к MTU пути, чтобы крупные TLS-пакеты не уходили в чёрную дыру на сотовом канале."

msgid "Default"
msgstr "По умолчанию"

msgid "router-only"
msgstr "только роутер"

msgid "Affects only traffic the router itself originates (DNS, updates) — not devices streaming through it."
msgstr "Влияет только на трафик, который создаёт сам роутер (DNS, обновления) — не на устройства, стримящие через него."

msgid "WAN interface (blank = auto)"
msgstr "WAN-интерфейс (пусто = авто)"

msgid "auto-detect"
msgstr "автоопределение"

msgid "Active profile"
msgstr "Активный профиль"

msgid "WAN interface"
msgstr "WAN-интерфейс"

msgid "not available"
msgstr "недоступно"

msgid "unknown"
msgstr "неизвестно"

msgid "Kernel BBR version"
msgstr "Версия BBR в ядре"

msgid "Detected from tcp_bbr.ko size: %s B (modinfo is stripped on OpenWRT)"
msgstr "Определено по размеру tcp_bbr.ko: %s Б (modinfo в OpenWRT вырезан)"

# ---- v2.0: два профиля, проба MTU ----
msgid "Auto LTE"
msgstr "Авто LTE"

msgid "Home, wired"
msgstr "Дом, провод"

msgid "Determine optimal MTU"
msgstr "Определить оптимальный MTU"

msgid "Probing…"
msgstr "Зондирование…"

msgid "Path MTU: %s (%s) → MSS %s. Apply to set it."
msgstr "Path MTU: %s (%s) → MSS %s. Нажмите «Применить», чтобы задать."

msgid "Path MTU: %s (%s) → MSS %s. Press “Apply selected” to set it."
msgstr "Path MTU: %s (%s) → MSS %s. Нажмите «Применить выбранное», чтобы задать."

msgid "Probe failed — install iputils-tracepath"
msgstr "Проба не удалась — установите iputils-tracepath"

msgid "Probe failed — install iputils-ping"
msgstr "Проба не удалась — установите iputils-ping"

msgid "Revert all StreamTune optimizations and turn all toggles off?"
msgstr "Сбросить все оптимизации StreamTune и выключить все тумблеры?"

msgid "A router only forwards your phone’s streams — it is not the TCP endpoint. So TCP/buffer sysctls (tagged “router-only”) affect only the router’s own traffic, not the audio stream."
msgstr "Роутер лишь форвардит потоки телефона — он не является TCP-эндпоинтом. Поэтому TCP/буферные sysctl (с тегом «только роутер») влияют лишь на собственный трафик роутера, а не на аудиопоток."

msgid "Keep IPv6 enabled and the modem APN as IPV4V6: mobile carriers often use 464XLAT/CLAT, and disabling IPv6 can break connectivity."
msgstr "Держите IPv6 включённым, а APN модема — IPV4V6: мобильные операторы часто используют 464XLAT/CLAT, и отключение IPv6 может разорвать связь."

msgid "When several devices share the car link, install luci-app-sqm with cake-autorate (adaptive shaping for variable cellular bandwidth) — for a single audio stream it is not needed."
msgstr "Когда канал в машине делят несколько устройств, поставьте luci-app-sqm с cake-autorate (адаптивный шейпинг под переменную сотовую полосу) — для одного аудиопотока не нужно."

msgid "In a moving vehicle do not hard-lock LTE bands — free handover keeps coverage continuous; add a modem keepalive/watchdog for stuck connections."
msgstr "В движущейся машине не лочьте жёстко LTE-бэнды — свободный хэндовер сохраняет покрытие; добавьте keepalive/watchdog модема для зависших соединений."

msgid "“RX backlog drops / NAPI squeezes” above is informational: non-zero values mean the per-CPU packet queue or NAPI budget is saturating — the netdev_max_backlog / netdev_budget recommendations directly address that."
msgstr "«Дропы RX-очереди / squeeze NAPI» выше — справочно: ненулевые значения означают, что очередь пакетов на CPU или бюджет NAPI насыщаются — рекомендации netdev_max_backlog / netdev_budget как раз это и лечат."

msgid "On"
msgstr "Вкл"

msgid "Reset all"
msgstr "Сбросить всё"

msgid "Enable/disable every parameter in this block"
msgstr "Включить/выключить все параметры блока"

msgid "%d of %d recommendations met"
msgstr "Выполнено рекомендаций: %d из %d"

msgid "Tune the network stack for low-latency, low-jitter audio/video streaming. Pick a profile, toggle the parameters you want and apply."
msgstr "Настройте сетевой стек под аудио-/видеостриминг с низкой задержкой и джиттером. Выберите профиль, отметьте нужные параметры и примените."

msgid "Reset all StreamTune changes back to their original values and clear the applied-state memory?"
msgstr "Сбросить все изменения StreamTune к исходным значениям и очистить память применённого?"

msgid "Reset done. Applied parameters were restored to their original values."
msgstr "Сброшено. Применённые параметры восстановлены к исходным значениям."

msgid "Recommended OFF: NAT offload bypasses the fq_codel AQM and conflicts with Podkop policy-routing. Enable the toggle to enforce it off."
msgstr "Рекомендуется ВЫКЛ: NAT-offload обходит AQM fq_codel и конфликтует с policy-routing Podkop. Включите тумблер, чтобы принудительно выключить."

msgid "Recommended OFF on a dual-core router (neutral to harmful). Enable the toggle to stop and disable the service."
msgstr "Рекомендуется ВЫКЛ на двухъядерном роутере (нейтрально/вредно). Включите тумблер, чтобы остановить и отключить службу."

msgid "Time budget per NAPI poll cycle (µs); raise alongside netdev_budget so the packet limit, not the timer, governs."
msgstr "Временной бюджет одного цикла NAPI-поллинга (мкс); поднимайте вместе с netdev_budget, чтобы лимитом был пакетный, а не таймер."

msgid "RX backlog drops / NAPI squeezes"
msgstr "Дропы RX-очереди / squeeze NAPI"

msgid "WAN IPv6"
msgstr "IPv6 на WAN"

msgid "DHCPv6 server (LAN)"
msgstr "DHCPv6-сервер (LAN)"

msgid "Router Advertisement (RA)"
msgstr "Router Advertisement (RA)"

msgid "NDP proxy"
msgstr "NDP-прокси"

msgid "ULA prefix"
msgstr "ULA-префикс"

msgid "odhcpd service"
msgstr "Служба odhcpd"

msgid "Disable IPv6 on the WAN interface(s)."
msgstr "Отключить IPv6 на WAN-интерфейсе(ах)."

msgid "DHCPv6 server handed to LAN clients (odhcpd); disabled = no IPv6 addressing."
msgstr "DHCPv6-сервер для LAN-клиентов (odhcpd); disabled = нет выдачи IPv6-адресов."

msgid "IPv6 Router Advertisements to LAN; disabled = clients get no IPv6 default route."
msgstr "IPv6 Router Advertisements в LAN; disabled = клиенты не получают IPv6-маршрут по умолчанию."

msgid "NDP proxy; disabled with full IPv6 off."
msgstr "NDP-прокси; отключается при полном выключении IPv6."

msgid "Unique Local Address prefix; removed when IPv6 is fully off (restored on Reset all)."
msgstr "Префикс Unique Local Address; удаляется при полном выключении IPv6 (восстанавливается через «Сбросить всё»)."

msgid "odhcpd daemon (RA/DHCPv6/NDP); stopped and disabled when IPv6 is fully off."
msgstr "Демон odhcpd (RA/DHCPv6/NDP); останавливается и отключается при полном выключении IPv6."

msgid "stopped / not installed"
msgstr "остановлен / не установлен"

msgid "disabled / removed"
msgstr "отключено / удалено"

msgid "on (default)"
msgstr "вкл (по умолчанию)"

msgid "enabled (server)"
msgstr "включено (server)"

msgid "disabled"
msgstr "отключено"

msgid "removed"
msgstr "удалено"

msgid "Core-aware: recommended OFF on 1–3 cores (overhead not worth it, harmful on 1–2), ON from 4 cores. The toggle enforces the recommendation for your CPU."
msgstr "С учётом числа ядер: рекомендуется ВЫКЛ на 1–3 ядрах (накладные расходы не оправданы, на 1–2 вредно), ВКЛ от 4 ядер. Тумблер применяет рекомендацию под твой CPU."

msgid "Full IPv6 off — every item changed is listed below: kernel stack, WAN IPv6, DHCPv6/RA/NDP per pool, ULA prefix and odhcpd. Risky in general (can break 464XLAT/CLAT on mobile); here clients are IPv4-only by design."
msgstr "Полное выключение IPv6 — ниже перечислено всё, что меняется: стек ядра, IPv6 на WAN, DHCPv6/RA/NDP по каждому пулу, ULA-префикс и odhcpd. В целом рискованно (на сотовом может сломать 464XLAT/CLAT); здесь клиенты по замыслу только IPv4."

msgid "Internet profile:"
msgstr "Интернет-профиль:"

msgid "LTE"
msgstr "LTE"

msgid "Wired"
msgstr "Wired"

msgid "BBR: %s"
msgstr "BBR: %s"

msgid "optional — “Apply selected” determines and applies it automatically"
msgstr "необязательно — «Применить выбранное» само определит и применит"

msgid "Boot timeline is captured at boot; the kernel ring buffer no longer holds the early-boot lines (uptime %s). Reboot once to populate it."
msgstr "Хронология загрузки снимается на старте; кольцевой буфер ядра уже не содержит ранних строк загрузки (аптайм %s). Перезагрузите роутер один раз, чтобы заполнить её."

msgid "h"
msgstr "ч"

msgid "min"
msgstr "мин"

msgid "Overview"
msgstr "Обзор"

msgid "Diagnostics"
msgstr "Диагностика"
