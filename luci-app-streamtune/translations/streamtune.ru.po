msgstr "Этапы ядра, разобранные из dmesg."

msgid "System"
msgstr "Система"

msgid "Resources relevant to network load."
msgstr "Ресурсы, важные для сетевой нагрузки."

msgid "CPU cores"
msgstr "Ядра CPU"

msgid "RAM total"
msgstr "Всего ОЗУ"

msgid "RAM available"
msgstr "Доступно ОЗУ"

