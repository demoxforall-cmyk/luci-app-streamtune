# ---- категории ----
msgid "Network buffers (TCP/UDP)"
msgstr "Сетевые буферы (TCP/UDP)"

msgid "Larger socket buffers reduce packet drops at high bitrate — fewer rebuffering events while streaming."
msgstr "Большие буферы сокетов снижают потери пакетов на высоком битрейте — меньше перебуферизаций при стриминге."

msgid "Low-latency TCP"
msgstr "TCP с низкой задержкой"

msgid "Keep long streaming sessions fast: no slow-start after idle pauses, quicker socket reuse."
msgstr "Держит длинные сессии стриминга быстрыми: без замедления после пауз, быстрее переиспользование сокетов."

msgid "Queues & backlog"
msgstr "Очереди и backlog"

msgid "Absorb traffic bursts without dropping packets (device backlog and NAPI budget)."
msgstr "Поглощает всплески трафика без потери пакетов (backlog устройства и бюджет NAPI)."

msgid "Congestion control (BBR + fq)"
msgstr "Управление перегрузкой (BBR + fq)"

msgid "BBR with fair queueing fights bufferbloat and keeps latency low under load."
msgstr "BBR с честной очередью борется с bufferbloat и удерживает низкую задержку под нагрузкой."

msgid "Flow offloading"
msgstr "Разгрузка потоков (offload)"

msgid "Offload NAT (software, and hardware on supported SoCs) to cut CPU load and jitter."
msgstr "Выгрузка NAT (программно, и аппаратно на поддерживаемых SoC) для снижения нагрузки CPU и джиттера."

msgid "Connection tracking"
msgstr "Отслеживание соединений (conntrack)"

msgid "A bigger conntrack hash table speeds up lookups when there are many connections."
msgstr "Большая хэш-таблица conntrack ускоряет поиск при множестве соединений."

msgid "IRQ balancing"
msgstr "Балансировка прерываний (IRQ)"

msgid "Spread network interrupts across CPU cores to smooth out load spikes."
msgstr "Распределяет сетевые прерывания по ядрам CPU, сглаживая пики нагрузки."

msgid "Disable IPv6"
msgstr "Отключить IPv6"

msgid "Removes the RA/DHCPv6 handshake — faster boot and less jitter. Enable only if you do not use IPv6."
msgstr "Убирает RA/DHCPv6-handshake — быстрее загрузка и меньше джиттера. Включайте только если IPv6 не нужен."

# ---- метки параметров ----
msgid "Software offload"
msgstr "Программный offload"

msgid "Hardware offload"
msgstr "Аппаратный offload"

msgid "conntrack hashsize"
msgstr "размер хэша conntrack"

msgid "irqbalance service"
msgstr "служба irqbalance"

# ---- подсказки по параметрам ----
msgid "Maximum socket receive buffer size."
msgstr "Максимальный размер буфера приёма сокета."

msgid "Maximum socket send buffer size."
msgstr "Максимальный размер буфера отправки сокета."

msgid "Default socket receive buffer size."
msgstr "Размер буфера приёма сокета по умолчанию."

msgid "Default socket send buffer size."
msgstr "Размер буфера отправки сокета по умолчанию."

msgid "Maximum ancillary buffer size per socket."
msgstr "Максимальный размер служебного буфера на сокет."

msgid "TCP receive auto-tuning limits: min / default / max."
msgstr "Пределы авто-тюнинга приёма TCP: мин / по умолчанию / макс."

msgid "TCP send auto-tuning limits: min / default / max."
msgstr "Пределы авто-тюнинга отправки TCP: мин / по умолчанию / макс."

msgid "Minimum UDP receive buffer guaranteed per socket."
msgstr "Минимальный гарантированный буфер приёма UDP на сокет."

msgid "Minimum UDP send buffer guaranteed per socket."
msgstr "Минимальный гарантированный буфер отправки UDP на сокет."

msgid "0 = do not slow a connection after an idle pause — critical for streaming."
msgstr "0 = не замедлять соединение после паузы простоя — критично для стриминга."

msgid "Reuse TIME_WAIT sockets for new outgoing connections."
msgstr "Переиспользовать сокеты TIME_WAIT для новых исходящих соединений."

msgid "Seconds to keep a socket in FIN-WAIT-2."
msgstr "Сколько секунд держать сокет в FIN-WAIT-2."

msgid "Queue of half-open connections awaiting ACK."
msgstr "Очередь полуоткрытых соединений в ожидании ACK."

msgid "Maximum number of TIME_WAIT sockets."
msgstr "Максимальное число сокетов TIME_WAIT."

msgid "Packets queued when an interface delivers faster than the kernel handles."
msgstr "Очередь пакетов, когда интерфейс отдаёт быстрее, чем ядро обрабатывает."

msgid "Packets processed per NAPI poll cycle."
msgstr "Пакетов за один цикл опроса NAPI."

msgid "Congestion control algorithm; bbr is recommended for streaming."
msgstr "Алгоритм управления перегрузкой; для стриминга рекомендуется bbr."

msgid "Default queueing discipline; fq pairs with BBR."
msgstr "Дисциплина очереди по умолчанию; fq в паре с BBR."

msgid "Software flow offloading in the firewall."
msgstr "Программная разгрузка потоков в межсетевом экране."

msgid "Hardware NAT offloading (requires a supported SoC)."
msgstr "Аппаратная разгрузка NAT (нужен поддерживаемый SoC)."

msgid "Number of buckets in the conntrack hash table."
msgstr "Число корзин в хэш-таблице conntrack."

msgid "irqbalance daemon that distributes IRQs across cores."
msgstr "Демон irqbalance, распределяющий IRQ по ядрам."

msgid "Disable IPv6 on all interfaces."
msgstr "Отключить IPv6 на всех интерфейсах."

msgid "Disable IPv6 on the default interface template."
msgstr "Отключить IPv6 в шаблоне интерфейса по умолчанию."

