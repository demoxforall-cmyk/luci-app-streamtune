msgstr "Применить выбранное"

msgid "Recommended preset"
msgstr "Рекомендуемый профиль"

msgid "Revert all"
msgstr "Сбросить всё"

msgid "optional"
msgstr "опционально"

msgid "risky"
msgstr "риск"

msgid "Enable hardware NAT offloading"
msgstr "Включить аппаратную разгрузку NAT"

msgid "(hardware offload not detected on this device)"
msgstr "(аппаратный offload на этом устройстве не обнаружен)"

